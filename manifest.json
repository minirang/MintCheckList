{
    "manifest_version": 3,
    "name": "Mint Checklist",
    "version": "1.0",
    "description": "간단한 체크리스트",
    "action": {
        "default_popup": "popup.html"
    },
    "permissions": [
        "storage"
    ],
    "icons": {
        "16": "icon.png",
        "48": "icon.png",
        "128": "icon.png"
    }
}